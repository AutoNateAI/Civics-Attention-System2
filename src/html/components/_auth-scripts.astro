---
const { mode = "public" } = Astro.props;
const pathname = Astro.url.pathname;
const pathSegments = pathname.split('/').filter((segment) => segment !== '');
const depth = pathSegments.length > 0 ? pathSegments.length - 1 : 0;
const deploymentPath = depth === 0 ? './' : '../'.repeat(depth);

const paths = {
  dashboard: `${deploymentPath}index2.html`,
  landing: `${deploymentPath}landing.html`,
  login: `${deploymentPath}examples/login.html`,
  register: `${deploymentPath}examples/register.html`
};

const serializedMode = JSON.stringify(mode);
const serializedPaths = JSON.stringify(paths);
---

<script is:inline>
(() => {
  const MODE = JSON.parse(${JSON.stringify(serializedMode)});
  const STORAGE_KEY = "cas-auth-user";
  const PATHS = JSON.parse(${JSON.stringify(serializedPaths)});
  let currentUser = null;

  const normaliseEmail = (value) => (typeof value === "string" ? value.trim().toLowerCase() : "");

  const readStoredUser = () => {
    try {
      const raw = window.localStorage.getItem(STORAGE_KEY);
      if (!raw) {
        return null;
      }
      const parsed = JSON.parse(raw);
      if (!parsed || typeof parsed !== "object") {
        return null;
      }
      return parsed;
    } catch (error) {
      console.error("Auth: unable to read stored user", error);
      return null;
    }
  };

  const persistUser = (user) => {
    currentUser = user;
    try {
      if (user) {
        window.localStorage.setItem(STORAGE_KEY, JSON.stringify(user));
      } else {
        window.localStorage.removeItem(STORAGE_KEY);
      }
    } catch (error) {
      console.error("Auth: unable to persist user", error);
    }
    updateUserUi();
  };

  const updateUserUi = () => {
    const displayName = currentUser?.name || "Guest";
    const displayEmail = currentUser?.email || "guest@example.com";

    document
      .querySelectorAll('[data-auth-user-name]')
      .forEach((element) => {
        element.textContent = displayName;
      });

    document
      .querySelectorAll('[data-auth-user-email]')
      .forEach((element) => {
        element.textContent = displayEmail;
      });

    document
      .querySelectorAll('[data-auth-when]')
      .forEach((element) => {
        const state = element.getAttribute('data-auth-when');
        if (state === 'signed-in') {
          element.classList.toggle('d-none', !currentUser);
        }
        if (state === 'signed-out') {
          element.classList.toggle('d-none', Boolean(currentUser));
        }
      });
  };

  const redirectTo = (url) => {
    if (!url) return;
    window.location.replace(url);
  };

  const guardRoutes = () => {
    if (MODE === 'protected' && !currentUser) {
      redirectTo(PATHS.landing);
      return;
    }

    if ((MODE === 'public' || MODE === 'landing') && currentUser) {
      redirectTo(PATHS.dashboard);
    }
  };

  const clearFormMessage = (form) => {
    const alert = form.querySelector('[data-auth-message]');
    if (!alert) return;
    alert.textContent = '';
    alert.classList.add('d-none');
    alert.classList.remove('alert-danger', 'alert-success');
  };

  const showFormMessage = (form, message, tone = 'danger') => {
    const alert = form.querySelector('[data-auth-message]');
    if (!alert) return;
    alert.textContent = message;
    alert.classList.remove('d-none', 'alert-danger', 'alert-success');
    alert.classList.add(`alert-${tone}`);
  };

  document.addEventListener('DOMContentLoaded', () => {
    currentUser = readStoredUser();
    updateUserUi();
    guardRoutes();
  });

  document.addEventListener('submit', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLFormElement)) return;

    const formType = target.dataset.authForm;
    if (!formType) return;

    event.preventDefault();
    clearFormMessage(target);

    if (formType === 'login') {
      const emailInput = target.querySelector('[name="email"]');
      const passwordInput = target.querySelector('[name="password"]');

      const email = normaliseEmail(emailInput?.value || '');
      const password = passwordInput?.value?.trim();

      if (!email || !password) {
        showFormMessage(target, 'Please enter both email and password.');
        return;
      }

      const stored = readStoredUser();
      if (!stored || normaliseEmail(stored.email) !== email) {
        showFormMessage(target, "We couldn't find an account with that email. Please sign up first.");
        return;
      }

      if (stored.password !== password) {
        showFormMessage(target, 'The password you entered is incorrect.');
        return;
      }

      persistUser(stored);
      redirectTo(PATHS.dashboard);
      return;
    }

    if (formType === 'signup') {
      const nameInput = target.querySelector('[name="name"]');
      const emailInput = target.querySelector('[name="email"]');
      const passwordInput = target.querySelector('[name="password"]');
      const termsInput = target.querySelector('[name="terms"]');

      const name = nameInput?.value?.trim();
      const email = normaliseEmail(emailInput?.value || '');
      const password = passwordInput?.value?.trim();
      const acceptedTerms = termsInput instanceof HTMLInputElement ? termsInput.checked : false;

      if (!name || !email || !password) {
        showFormMessage(target, 'Please complete all fields to continue.');
        return;
      }

      if (!acceptedTerms) {
        showFormMessage(target, 'Please accept the terms to create an account.');
        return;
      }

      const user = { name, email, password };
      persistUser(user);
      showFormMessage(target, 'Account created! Redirecting to your dashboard…', 'success');
      window.setTimeout(() => {
        redirectTo(PATHS.dashboard);
      }, 600);
    }
  });

  document.addEventListener('click', (event) => {
    const trigger = event.target instanceof Element ? event.target.closest('[data-auth-action="signout"]') : null;
    if (!trigger) return;
    event.preventDefault();
    persistUser(null);
    redirectTo(PATHS.landing);
  });
})();
</script>
